# Stable production default.
TTS_PROVIDER=openai
TEXT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TEXT_MODEL=gpt-4o-mini

# Experimental expressive provider. Prefer single-request generation for quota efficiency.
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_TTS_VOICE_CHLOE=Kore
GEMINI_TTS_VOICE_VIVIAN=Aoede
GEMINI_TTS_VOICE_MIA=Zephyr
GEMINI_TTS_VOICE_TITAN=Fenrir
GEMINI_TTS_VOICE_VINCENT=Charon
GEMINI_TTS_VOICE_ADAM=Puck
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Premium voice consistency provider.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_CHLOE=
ELEVENLABS_VOICE_ID_VIVIAN=
ELEVENLABS_VOICE_ID_MIA=
ELEVENLABS_VOICE_ID_TITAN=
ELEVENLABS_VOICE_ID_VINCENT=
ELEVENLABS_VOICE_ID_ADAM=

# Demo mode, no API keys required:
# TTS_PROVIDER=mock
# TEXT_PROVIDER=mock
